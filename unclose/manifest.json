{
  "name": "UndoCloseTab",
  "version": "4.0",
  "author": "MK & Wei Hu & Xerios",
  "description": "Undo your closed tabs",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "icons": { 
           "48": "icon.png",
            "128": "icon-128.png"
            },
  "options_page": "popup.html",
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html",
    "default_title": "Undo closed tabs"
  },
  "permissions": [
    "storage",
    "tabs"
  ]
}
